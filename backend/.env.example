# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/consultaplaca"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Admin padrão (seed) ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@consultaplaca.com
ADMIN_PASSWORD=Admin@123456

# ══════════════════════════════════════════════════════════════════════════════
# PROVIDERS DE CONSULTA VEICULAR
# Configure ao menos um provider para consultas em tempo real.
# Em desenvolvimento sem providers configurados, o MockProvider é ativado.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Provider Principal: ApiPlacas ────────────────────────────────────────────
# Site:          https://apiplacas.com.br
# Documentação:  https://apiplacas.com.br/doc.php
# Endpoint:      GET https://wdapi2.com.br/consulta/{placa}/{token}
# Dados:         marca, modelo, ano, cor, município, UF, chassi (mascarado),
#                situação, restrições, FIPE, ficha técnica parcial
#
APIPLACAS_TOKEN=seu_token_aqui

# ─── Provider 2: Custom (API privada alternativa) ─────────────────────────────
# Configure para qualquer outra API veicular brasileira
#
# PROVIDER_CUSTOM_URL=https://api.meuservico.com.br/v2
# PROVIDER_CUSTOM_KEY=sua_chave
# PROVIDER_CUSTOM_TOKEN=seu_token
# PROVIDER_CUSTOM_PATH=/veiculos/{placa}
# PROVIDER_CUSTOM_AUTH_TYPE=bearer
# PROVIDER_CUSTOM_AUTH_PARAM=token

# ─── Provider 3: BrasilAPI ────────────────────────────────────────────────────
# API pública e gratuita — sem chave necessária
# Usada automaticamente como fallback
# Documentação: https://brasilapi.com.br/docs

# ─── Mock Provider (desenvolvimento) ─────────────────────────────────────────
# Ativado automaticamente em NODE_ENV=development sem providers reais
# Para forçar mock em qualquer ambiente:
# ENABLE_MOCK_PROVIDER=true
